# Production Docker Compose: copy to .env and set values before:
#   docker compose -f docker-compose.prod.yml up --build -d

# Required: backend base URL (no trailing slash). Browser will call this for API and WebSocket.
VITE_API_BASE=https://api.example.com

# Optional: WebSocket access token (usually leave unset; use login/sessionStorage instead).
# VITE_WS_ACCESS_TOKEN=

# Optional: WebSocket ping interval in seconds (default 10).
# VITE_WS_PING_INTERVAL_SEC=10

# Documents → RAG upload: existing RAG dropdown (comma-separated) and workflow queue/pipeline
# VITE_RAG_OPTIONS=default,project-alpha
# VITE_RAG_QUEUE=olo-rag-queue
# VITE_RAG_PIPELINE=rag-upload
