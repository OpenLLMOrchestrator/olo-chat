# Backend URL so the app calls the API (REST and WebSocket). Use olo:7080 when chat runs in Docker and talks to olo service; ensure "olo" resolves (e.g. hosts or same network).
VITE_API_BASE=http://olo:7080

# Optional: WebSocket access token (leave unset for dev; use login/sessionStorage if needed).
# VITE_WS_ACCESS_TOKEN=

# Optional: WebSocket ping interval in seconds (default 10).
# VITE_WS_PING_INTERVAL_SEC=10
